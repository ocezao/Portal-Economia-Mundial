# Metabase (dashboard opcional do analytics)
# URL do Metabase (ex: https://metabase.seu-dominio.com.br)
METABASE_URL=
# API key de admin do Metabase (NAO commitar). Alternativa: usar METABASE_ADMIN_EMAIL/METABASE_ADMIN_PASSWORD no script.
METABASE_API_KEY=
METABASE_ADMIN_EMAIL=
METABASE_ADMIN_PASSWORD=

# Fonte de dados que o Metabase vai consultar (padrao: usa DATABASE_URL)
METABASE_SOURCE_DB_URL=
METABASE_SOURCE_DB_NAME=Portal Postgres (analytics)
METABASE_SOURCE_DB_SSL=true

# Error Tracking (Sentry) - opcional
# Criar conta em https://sentry.io
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Cache Rate Limiting (Upstash Redis) - opcional para producao com multiplas instancias
# Criar conta em https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Backup (S3/Backblaze B2) - opcional
S3_BACKUP_ENABLED=false
S3_BACKUP_BUCKET=
S3_BACKUP_ENDPOINT=
S3_BACKUP_ACCESS_KEY=
S3_BACKUP_SECRET_KEY=

# Log level (debug, info, warn, error)
LOG_LEVEL=info
