# Public (browser) - Next.js requires NEXT_PUBLIC_ prefix
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Finnhub (browser). For better security, proxy these via an API route later.
NEXT_PUBLIC_FINNHUB_API_KEY="your-finnhub-key"
NEXT_PUBLIC_FINNHUB_ENABLED="true"
NEXT_PUBLIC_FINNHUB_FREE_PLAN="true"

# Finnhub (server-only, preferred for jobs/snapshots)
FINNHUB_API_KEY="your-finnhub-key"

# Backend (server-only)
SUPABASE_DB_PASSWORD="your-db-password"
SUPABASE_DB_URL="postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres"

# ⚠️ IMPORTANTE: Service Role Key tem acesso TOTAL ao banco
# Usado pelo MCP Server e funções administrativas
# NUNCA exponha no frontend - server-side only
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

SUPABASE_JWT_SECRET="your-jwt-secret"

# Uploads (server-only)
# Nome do bucket no Supabase Storage usado por `POST /api/upload`
SUPABASE_UPLOAD_BUCKET="uploads"

# When true, pages should prefer snapshots and avoid per-request external API calls.
# Useful for small VPS. Keep false in dev if you want fallbacks.
EXTERNAL_SNAPSHOTS_REQUIRE="false"

# App (public)
NEXT_PUBLIC_SITE_URL="https://seu-dominio.com"
NEXT_PUBLIC_API_BASE_URL="https://api.seu-dominio.com"

# AdSense (public)
# Client ID: use o formato `ca-pub-...` (script). No `ads.txt` o formato é `pub-...`.
NEXT_PUBLIC_ADSENSE_CLIENT_ID="ca-pub-0000000000000000"
NEXT_PUBLIC_ADSENSE_SLOT_HOME_INLINE="0000000000"
NEXT_PUBLIC_ADSENSE_SLOT_LAYOUT_FOOTER="0000000000"

# Web push (OneSignal)
NEXT_PUBLIC_ONESIGNAL_APP_ID="your-onesignal-app-id"
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
