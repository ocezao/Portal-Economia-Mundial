# Metabase (dashboard opcional do analytics)
# URL do Metabase (ex: https://metabase.seu-dominio.com.br)
METABASE_URL=
# API key de admin do Metabase (NAO commitar). Alternativa: usar METABASE_ADMIN_EMAIL/METABASE_ADMIN_PASSWORD no script.
METABASE_API_KEY=
METABASE_ADMIN_EMAIL=
METABASE_ADMIN_PASSWORD=

# Fonte de dados que o Metabase vai consultar (padrao: usa SUPABASE_DB_URL)
